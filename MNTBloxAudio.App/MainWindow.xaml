<Window x:Class="MNTBloxAudio.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:core="clr-namespace:MNTBloxAudio.Core.Models;assembly=MNTBloxAudio.Core"
        mc:Ignorable="d"
        Title="MNTBloxAudio"
        Width="1180"
        Height="820"
        MinWidth="860"
        MinHeight="620"
        Background="{StaticResource WindowBrush}"
        FontFamily="Segoe UI Variable Text"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <MediaElement x:Name="PreviewPlayer"
                      Width="0"
                      Height="0"
                      Opacity="0"
                      LoadedBehavior="Play"
                      UnloadedBehavior="Stop"
                      Source="{Binding PreviewAudioSource}"
                      MediaOpened="PreviewPlayer_OnMediaOpened"
                      MediaEnded="PreviewPlayer_OnMediaEnded"
                      MediaFailed="PreviewPlayer_OnMediaFailed" />

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="28"
                       FontWeight="SemiBold"
                       Text="MNTBloxAudio" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource MutedTextBrush}"
                       Text="Minimal local Roblox audio replacement. Enable a rule, choose a file, and save once to apply it."
                       TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,18,0,18"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Foreground="{StaticResource MutedTextBrush}"
                               Text="Roblox sessions" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Text="{Binding RobloxSessionCount}" />
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}"
                               Text="Rules" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Text="{Binding RuleCount}" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}"
                               Text="Mode" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="{Binding ReplacementModeText}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="2">
            <TabItem Header="Rules">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.15*" />
                        <ColumnDefinition Width="0.85*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.ColumnSpan="2"
                               Margin="0,0,0,16"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="Enabled rules replace the local Roblox cache. Disabled rules leave the original audio alone."
                               TextWrapping="Wrap" />

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,0,18,0"
                            Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0"
                                       Margin="0,0,0,12">
                                <TextBlock DockPanel.Dock="Left"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="Rules" />

                                <WrapPanel DockPanel.Dock="Right"
                                           HorizontalAlignment="Right">
                                    <Button Style="{StaticResource SubtleButtonStyle}"
                                            Content="Add"
                                            Command="{Binding AddRuleCommand}" />
                                    <Button Style="{StaticResource SubtleButtonStyle}"
                                            Content="Apply All"
                                            Command="{Binding ApplyAllRulesCommand}" />
                                    <Button Style="{StaticResource SubtleButtonStyle}"
                                            Content="Remove"
                                            Command="{Binding RemoveSelectedRuleCommand}" />
                                    <Button Style="{StaticResource SubtleButtonStyle}"
                                            Content="Reset + Refresh"
                                            Command="{Binding RefreshCommand}" />
                                </WrapPanel>
                            </DockPanel>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding Rules}"
                                      SelectedItem="{Binding SelectedRule}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="On"
                                                            Binding="{Binding IsEnabled}"
                                                            Width="56" />
                                    <DataGridTextColumn Header="Rule"
                                                        Binding="{Binding Name}"
                                                        Width="1.1*" />
                                    <DataGridTextColumn Header="Asset ID"
                                                        Binding="{Binding AssetIdPattern}"
                                                        Width="1.1*" />
                                    <DataGridTextColumn Header="File"
                                                        Binding="{Binding FileNameDisplay}"
                                                        Width="1.4*" />
                                    <DataGridTextColumn Header="State"
                                                        Binding="{Binding StatusDisplay}"
                                                        Width="100" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource CardBorderStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="Selected Rule" />
                                <TextBlock Margin="0,6,0,16"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="One button handles this rule. If it is enabled, the app prepares it and applies the cache replacement. If it is disabled, the app keeps Roblox's original audio."
                                           TextWrapping="Wrap" />

                                <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                           Text="Name" />
                                <TextBox Text="{Binding SelectedRule.Name, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                           Text="Exact Roblox asset ID" />
                                <TextBox Text="{Binding SelectedRule.AssetIdPattern, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                           Text="Replacement file, URL, or 6-letter song code" />
                                <DockPanel LastChildFill="True">
                                    <Button DockPanel.Dock="Right"
                                            Margin="12,0,0,0"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Content="Browse File"
                                            Command="{Binding BrowseSelectedRuleCommand}" />
                                    <TextBox Text="{Binding SelectedRule.FilePath, UpdateSourceTrigger=PropertyChanged}" />
                                </DockPanel>

                                <CheckBox Margin="0,14,0,0"
                                          IsChecked="{Binding SelectedRule.IsEnabled}"
                                          Content="Enable replacement for this rule" />

                                <UniformGrid Margin="0,16,0,16"
                                             Columns="2">
                                    <Border Margin="0,0,8,0"
                                            Padding="12"
                                            CornerRadius="12"
                                            Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource CardBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                       Text="Roblox source" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding SelectedRule.SourceAssetSizeDisplay, Mode=OneWay}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Text="{Binding SelectedRule.StatusDisplay, Mode=OneWay}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="8,0,0,0"
                                            Padding="12"
                                            CornerRadius="12"
                                            Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource CardBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                       Text="Replacement source" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding SelectedRule.ReplacementFileSizeDisplay, Mode=OneWay}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Text="{Binding SelectedRule.FileNameDisplay, Mode=OneWay}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="12"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Text="{Binding SelectedRule.ReplacementSourceNoteDisplay, Mode=OneWay}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <WrapPanel>
                                    <Button Style="{StaticResource SubtleButtonStyle}"
                                            Content="Preview Rule"
                                            Command="{Binding PlaySelectedRuleCommand}" />
                                    <Button Content="Save + Apply Rule"
                                            Command="{Binding SaveAndApplySelectedRuleCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Upload">
                <Grid Margin="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*" />
                        <ColumnDefinition Width="0.95*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Margin="0,0,18,0"
                            Style="{StaticResource CardBorderStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="Submit To MNTBloxIndex" />
                                <TextBlock Margin="0,6,0,16"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="This tab submits song metadata plus a direct audio URL to the Vercel-hosted song index API. The same base URL is also used when a 6-letter song code is resolved into a real audio link."
                                           TextWrapping="Wrap" />

                                <Border Padding="12"
                                        CornerRadius="12"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource CardBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                   Text="Device ID" />
                                        <DockPanel Margin="0,4,0,0"
                                                   LastChildFill="True">
                                            <Button DockPanel.Dock="Right"
                                                    Margin="12,0,0,0"
                                                    Style="{StaticResource SubtleButtonStyle}"
                                                    Content="Copy"
                                                    Command="{Binding CopyDeviceIdCommand}" />
                                            <TextBox Text="{Binding DeviceId}"
                                                     IsReadOnly="True" />
                                        </DockPanel>
                                        <TextBlock Margin="0,10,0,0"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Text="Song index base URL" />
                                        <TextBox Margin="0,4,0,0"
                                                 Text="{Binding SongIndexBaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Margin="0,16,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="Direct audio URL" />
                                <TextBox Text="{Binding UploadAudioUrl, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                           Text="Song name" />
                                <TextBox Text="{Binding UploadSongName, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                           Text="Artist" />
                                <TextBox Text="{Binding UploadArtist, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                           Text="Uploader name (optional)" />
                                <TextBox Text="{Binding UploadUploaderName, UpdateSourceTrigger=PropertyChanged}" />

                                <Border Margin="0,16,0,0"
                                        Padding="12"
                                        CornerRadius="12"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource CardBorderBrush}"
                                        BorderThickness="1">
                                    <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                               Text="{Binding UploadStatusText}"
                                               TextWrapping="Wrap" />
                                </Border>

                                <Button Margin="0,16,0,0"
                                        Content="Submit Link"
                                        Command="{Binding UploadAudioCommand}" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="My Submissions" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                               Text="Only songs submitted by this device ID can be deleted from here."
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <ListBox Grid.Row="1"
                                     Margin="0,14,0,14"
                                     ItemsSource="{Binding UploadedSongs}"
                                     SelectedItem="{Binding SelectedUploadedSong}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type core:UploadedSongRecord}">
                                        <Border Margin="0,0,0,8"
                                                Padding="10"
                                                CornerRadius="10"
                                                Background="{StaticResource SurfaceAltBrush}"
                                                BorderBrush="{StaticResource CardBorderBrush}"
                                                BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding SummaryDisplay}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           Text="{Binding Code}" />
                                                <TextBlock Margin="0,2,0,0"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           Text="{Binding AudioUrl}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Border Grid.Row="2"
                                    Margin="0,0,0,14"
                                    Padding="12"
                                    CornerRadius="12"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource CardBorderBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding PreviewHeading}" />
                                    <TextBlock Margin="0,4,0,10"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="{Binding PreviewStatusText}"
                                               TextWrapping="Wrap" />
                                    <WrapPanel>
                                        <Button Style="{StaticResource SubtleButtonStyle}"
                                                Content="Preview Typed URL"
                                                Command="{Binding PreviewTypedAudioCommand}" />
                                        <Button Style="{StaticResource SubtleButtonStyle}"
                                                Content="Play Selected Upload"
                                                Command="{Binding PreviewSelectedUploadCommand}" />
                                        <Button Content="Stop Preview"
                                                Command="{Binding StopPreviewCommand}" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <WrapPanel Grid.Row="3">
                                <Button Content="Delete Selected Upload"
                                        Command="{Binding DeleteSelectedUploadCommand}" />
                            </WrapPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Songs">
                <Grid Margin="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*" />
                        <ColumnDefinition Width="0.95*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Margin="0,0,18,0"
                            Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="Song Search" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="This tab searches the song index directly through the API. No browser view is used here."
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Margin="0,14,0,14"
                                    Style="{StaticResource CardBorderStyle}">
                                <DockPanel LastChildFill="True">
                                    <WrapPanel DockPanel.Dock="Right"
                                               Margin="12,0,0,0">
                                        <Button Style="{StaticResource SubtleButtonStyle}"
                                                Content="All Songs"
                                                Command="{Binding LoadAllSongsCommand}" />
                                        <Button Content="Search"
                                                Command="{Binding SearchSongsCommand}" />
                                    </WrapPanel>
                                    <TextBox Margin="0"
                                             Text="{Binding SongSearchQuery, UpdateSourceTrigger=PropertyChanged}" />
                                </DockPanel>
                            </Border>

                            <Grid Grid.Row="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                           Text="{Binding SongSearchStatusText}"
                                           TextWrapping="Wrap" />

                                <ListBox Grid.Row="1"
                                         Margin="0,14,0,0"
                                         ItemsSource="{Binding SongSearchResults}"
                                         SelectedItem="{Binding SelectedSongSearchResult}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type core:SongIndexEntry}">
                                            <Border Margin="0,0,0,8"
                                                    Padding="10"
                                                    CornerRadius="10"
                                                    Background="{StaticResource SurfaceAltBrush}"
                                                    BorderBrush="{StaticResource CardBorderBrush}"
                                                    BorderThickness="1">
                                                <StackPanel>
                                                    <DockPanel LastChildFill="False">
                                                        <TextBlock DockPanel.Dock="Left"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding SongName}" />
                                                        <TextBlock DockPanel.Dock="Right"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   Text="{Binding Code}" />
                                                    </DockPanel>
                                                    <TextBlock Margin="0,4,0,0"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               Text="{Binding Artist}" />
                                                    <TextBlock Margin="0,2,0,0"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               Text="{Binding UploaderName}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="Selected Song" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="Preview the selected song, copy its code, or assign that code to the selected rule."
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Margin="0,14,0,14"
                                    Padding="12"
                                    CornerRadius="12"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource CardBorderBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding SelectedSongSearchResult.SongName, TargetNullValue=No song selected}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="{Binding SelectedSongSearchResult.Artist, TargetNullValue=Search to load songs from the API}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="{Binding SelectedSongSearchResult.Code}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="{Binding SelectedSongSearchResult.UploaderName}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="{Binding SelectedSongSearchResult.AudioUrl}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2"
                                    Margin="0,0,0,14"
                                    Padding="12"
                                    CornerRadius="12"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource CardBorderBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding PreviewHeading}" />
                                    <TextBlock Margin="0,4,0,10"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="{Binding PreviewStatusText}"
                                               TextWrapping="Wrap" />
                                    <WrapPanel>
                                        <Button Style="{StaticResource SubtleButtonStyle}"
                                                Content="Play Song"
                                                Command="{Binding PreviewSelectedSongSearchResultCommand}" />
                                        <Button Style="{StaticResource SubtleButtonStyle}"
                                                Content="Copy Code"
                                                Command="{Binding CopySelectedSongCodeCommand}" />
                                        <Button Style="{StaticResource SubtleButtonStyle}"
                                                Content="Stop Preview"
                                                Command="{Binding StopPreviewCommand}" />
                                        <Button Content="Use Code In Rule"
                                                Command="{Binding UseSelectedSongCodeCommand}" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Row="3">
                                <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                           Text="Tip: after using a code in a rule, the rule source can stay as the 6-letter code and the app will resolve it through the index API when needed."
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Advanced">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="1.15*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Margin="0,0,0,18"
                            Style="{StaticResource CardBorderStyle}">
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="Advanced" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="Use this tab for background re-checks, cache inspection, and activity logs."
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <WrapPanel DockPanel.Dock="Right"
                                       HorizontalAlignment="Right">
                                <CheckBox VerticalAlignment="Center"
                                          IsChecked="{Binding UseDarkMode}"
                                          Content="Dark mode" />
                                <CheckBox VerticalAlignment="Center"
                                          IsChecked="{Binding AutoApplyCacheReplacements}"
                                          Content="Auto-apply on re-fetch" />
                                <Button Style="{StaticResource SubtleButtonStyle}"
                                        Content="Apply All"
                                        Command="{Binding ApplyAllRulesCommand}" />
                                <Button Style="{StaticResource SubtleButtonStyle}"
                                        Content="Prepare Enabled"
                                        Command="{Binding PrepareRuleAssetsCommand}" />
                                <Button Style="{StaticResource SubtleButtonStyle}"
                                        Content="Reset + Refresh"
                                        Command="{Binding RefreshCommand}" />
                                <Button Content="Save"
                                        Command="{Binding SaveConfigurationCommand}" />
                            </WrapPanel>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="0,0,0,18"
                            Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Cached Sounds" />

                            <DataGrid Grid.Row="1"
                                      Margin="0,14,0,0"
                                      ItemsSource="{Binding CachedSoundFiles}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="File"
                                                        Binding="{Binding FileName}"
                                                        Width="1.5*" />
                                    <DataGridTextColumn Header="Cache KB"
                                                        Binding="{Binding LengthDisplay}"
                                                        Width="100" />
                                    <DataGridTextColumn Header="Asset ID"
                                                        Binding="{Binding MatchedAssetId}"
                                                        Width="120" />
                                    <DataGridTextColumn Header="Rule"
                                                        Binding="{Binding MatchedRuleName}"
                                                        Width="1.1*" />
                                    <DataGridTextColumn Header="State"
                                                        Binding="{Binding StatusText}"
                                                        Width="100" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Activity" />

                            <ListBox Grid.Row="1"
                                     Margin="0,14,0,0"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ItemsSource="{Binding Activity}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type core:ActivityLogEntry}">
                                        <Border Margin="0,0,0,8"
                                                Padding="10"
                                                CornerRadius="10"
                                                Background="{StaticResource SurfaceAltBrush}"
                                                BorderBrush="{StaticResource CardBorderBrush}"
                                                BorderThickness="1">
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Left"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Category}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           Text="{Binding Timestamp, StringFormat={}{0:hh:mm:ss tt}}" />
                                                <TextBlock Margin="0,22,0,0"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding Message}" />
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
